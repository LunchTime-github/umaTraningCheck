{
  "name": "umatraningcheck",
  "version": "2.0.0",
  "description": "우마무스메 육성 기록 앱",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite build --watch --mode development\" \"wait-on dist/renderer/index.html && electron .\"",
    "start": "vite build && electron .",
    "build": "vite build && electron-builder",
    "vite:dev": "vite"
  },
  "keywords": ["umamusume", "training", "electron", "react"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "chart.js": "^4.4.4",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "vite": "^6.0.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.umatraining.check",
    "productName": "우마무스메 육성 기록",
    "files": [
      "dist/renderer/**",
      "main.js",
      "preload.js",
      "data/**"
    ],
    "directories": { "output": "dist/app" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" }
  }
}
